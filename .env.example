PORT=8080
HMAC_SECRET=testsecret
REPORTS_DIR=./reports
STATIC_DIR=./static
DATABASES_CONFIG=./databases.yaml
ENABLE_PUBLIC_PATHS=false
ALLOWED_CDNS=https://cdn.jsdelivr.net,https://cdn.plot.ly
ALLOW_ORIGINS=*,http://localhost:9090,http://localhost:8080
# Query logging for development/troubleshooting
QUERY_LOGGING=false
QUERY_LOG_DIR=./query_log

# ===========================================================================
# Phase 1: Configurable NONCE & URL Expiry Settings
# ===========================================================================

# URL Expiration Settings
URL_EXPIRY_DEFAULT=5m
URL_EXPIRY_MIN=1m
URL_EXPIRY_MAX=24h
REFRESH_GRACE_PERIOD=0s

# NONCE Settings
NONCE_BYTES=32
NONCE_ENCODING=urlsafe-base64
NONCE_MAX_AGE=24h
NONCE_CLEANUP_INTERVAL=60s
NONCE_MAX_USES=1
NONCE_USE_WINDOW=5m