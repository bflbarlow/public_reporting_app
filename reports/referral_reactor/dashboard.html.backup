<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Referral Reactor Core</title>
  <style>
    body {
      margin: 0;
      overflow: hidden;
      background: radial-gradient(circle at center, #0a0a15, #000);
      font-family: system-ui, sans-serif;
      color: #fff;
    }
    #loading {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: #9ca3ff;
      font-size: 18px;
    }
    #error {
      display: none;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(0,0,0,0.8);
      color: #f87171;
      padding: 20px;
      border-radius: 8px;
      max-width: 80%;
    }
    #info {
      position: absolute;
      top: 20px;
      left: 20px;
      background: rgba(0,0,0,0.45);
      padding: 12px;
      border-radius: 8px;
      font-size: 13px;
      backdrop-filter: blur(6px);
    }
    #info h2 {
      margin: 0 0 6px 0;
      font-size: 16px;
      color: #9ca3ff;
    }
    .control-btn {
      background: rgba(0,0,0,0.45);
      border: 1px solid #333;
      border-radius: 6px;
      color: #9ca3ff;
      padding: 8px 12px;
      font-size: 13px;
      cursor: pointer;
      backdrop-filter: blur(6px);
      transition: all 0.2s;
      white-space: nowrap;
    }
    .control-btn:hover {
      background: rgba(60, 60, 100, 0.7);
      border-color: #636efa;
    }
    .control-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
      background: rgba(0,0,0,0.45);
      padding: 10px;
      border-radius: 8px;
      backdrop-filter: blur(6px);
      border: 1px solid #333;
    }
    .control-label {
      font-size: 11px;
      color: #9ca3ff;
      margin-bottom: 2px;
    }
    .control-value {
      font-size: 12px;
      color: #c4b5fd;
      text-align: center;
      margin-top: 4px;
    }
    .slider-container {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    input[type="range"] {
      flex: 1;
      height: 6px;
      border-radius: 3px;
      background: rgba(60, 60, 100, 0.3);
      outline: none;
      -webkit-appearance: none;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: #9ca3ff;
      cursor: pointer;
      border: 2px solid #c4b5fd;
    }
    input[type="range"]::-moz-range-thumb {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: #9ca3ff;
      cursor: pointer;
      border: 2px solid #c4b5fd;
      border: none;
    }
    #tooltip {
      position: absolute;
      display: none;
      background: rgba(0,0,0,0.85);
      border: 1px solid #636efa;
      border-radius: 8px;
      padding: 12px;
      color: #d0d0ff;
      font-size: 12px;
      line-height: 1.4;
      max-width: 280px;
      z-index: 1000;
      backdrop-filter: blur(6px);
      pointer-events: none;
    }
    #tooltip h3 {
      margin: 0 0 6px 0;
      font-size: 13px;
      color: #9ca3ff;
    }
    #tooltip .row {
      margin-bottom: 4px;
    }
    #tooltip strong {
      color: #a5b4fc;
    }
    canvas {
      cursor: default;
    }
    canvas.panning {
      cursor: grabbing;
    }
    canvas.zooming {
      cursor: zoom-in;
    }
  </style>
  <script src="/static/thick_client.js"></script>
</head>
<body>

<div id="loading">Loading referral reactor...</div>
<div id="error" style="display: none;"></div>
<canvas id="reactor" style="display: none;"></canvas>
<div id="info"></div>
<div id="controls" style="position: absolute; top: 20px; right: 20px; display: flex; flex-direction: column; gap: 12px; z-index: 100;">
  <div class="control-group">
    <div class="control-label">Animation Speed</div>
    <div class="slider-container">
      <span style="color: #9ca3ff; font-size: 12px;">0.1x</span>
      <input type="range" id="speedSlider" min="0.1" max="3.0" step="0.1" value="1.0">
      <span style="color: #9ca3ff; font-size: 12px;">3.0x</span>
    </div>
    <div id="speedValue" class="control-value">1.0x</div>
  </div>
  
  <div class="control-group">
    <div class="control-label">Zoom & Pan</div>
    <div style="display: flex; gap: 6px; margin-bottom: 6px;">
      <button id="zoomInBtn" class="control-btn" title="Zoom In (or use Mouse Wheel)">+</button>
      <button id="zoomOutBtn" class="control-btn" title="Zoom Out (or use Mouse Wheel)">-</button>
      <button id="resetViewBtn" class="control-btn" title="Reset View (R)">Reset</button>
    </div>
    <div style="display: flex; gap: 6px;">
      <button id="pauseBtn" class="control-btn" title="Pause/Resume Animation (Space)">Pause</button>
    </div>
  </div>
</div>

<div id="tooltip"></div>
<div id="status" style="position: absolute; bottom: 20px; left: 20px; color: #9ca3ff; font-size: 12px; background: rgba(0,0,0,0.4); padding: 6px 10px; border-radius: 4px;">
  Animation: Running | Zoom: 1.00x | Pan: (0, 0) | Speed: 1.0x | Hover particles for details
</div>

<script defer>
(async function() {
  // Check for thick client
  if (!window.ReportApp) {
    console.error('ReportApp not loaded');
    document.getElementById('error').style.display = 'block';
    document.getElementById('error').innerHTML = '<h3>Error</h3><p>Thick client not loaded</p>';
    document.getElementById('loading').style.display = 'none';
    return;
  }
  
  // Wait for ReportApp to be ready
  if (!window.ReportApp.getParams) {
    await new Promise(resolve => window.ReportApp.on('ready', resolve));
  }
  
  // Ensure ReportConfig is available (injected by reporting_app)
  if (!window.ReportConfig) {
    console.log('Waiting for ReportConfig injection...');
    await new Promise(resolve => {
      const start = Date.now();
      const check = () => {
        if (window.ReportConfig) {
          resolve();
        } else if (Date.now() - start < 2000) {
          setTimeout(check, 10);
        } else {
          console.error('ReportConfig not injected after 2 seconds');
          resolve(); // Continue anyway, thick client might handle it
        }
      };
      check();
    });
  }
  
  console.log('ReportConfig after wait:', window.ReportConfig);
  
  // Helper to extract rows from datasource response
  function extractRows(data, datasourceName) {
    const ds = data[datasourceName];
    if (!ds || !ds.rows) return [];
    const columns = ds.columns;
    return ds.rows.map(row => {
      const obj = {};
      columns.forEach((col, idx) => {
        obj[col] = row[idx];
      });
      return obj;
    });
  }

  const canvas = document.getElementById('reactor');
  const ctx = canvas.getContext('2d');
  let W = canvas.width = window.innerWidth;
  let H = canvas.height = window.innerHeight;

  window.addEventListener('resize', () => {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  });

  try {
    const data = await window.ReportApp.refresh({});
    console.log('Data received:', data);
    const rows = extractRows(data, 'reactor_data');
    console.log('Rows extracted:', rows);
    
    // Hide loading, show canvas
    document.getElementById('loading').style.display = 'none';
    canvas.style.display = 'block';

  // Group by program
  const programs = {};
  rows.forEach(r => {
    if (!programs[r.program_numeric_id]) {
      programs[r.program_numeric_id] = {
        id: r.program_numeric_id,
        name: r.program_name,
        angle: Math.random() * Math.PI * 2,
        radius: 120 + Math.random() * 200,
        speed: 0.002 + Math.random() * 0.003,
        particles: []
      };
    }
    programs[r.program_numeric_id].particles.push(r);
  });

  // Animation control
  let animationRunning = true;
  let animationId = null;
  
  // Update status display
  function updateStatus() {
    const statusEl = document.getElementById('status');
    if (statusEl) {
      statusEl.textContent = `Animation: ${animationRunning ? 'Running' : 'Paused'} | Press Space to ${animationRunning ? 'pause' : 'resume'}`;
    }
  }
  
  // Pause/resume button
  document.getElementById('pauseBtn').addEventListener('click', () => {
    animationRunning = !animationRunning;
    document.getElementById('pauseBtn').textContent = animationRunning ? 'Pause' : 'Resume';
    updateStatus();
    
    if (animationRunning && !animationId) {
      // Restart animation if it was stopped
      loop();
    }
  });
  
  // Keyboard shortcut (Space)
  window.addEventListener('keydown', (evt) => {
    if (evt.key === ' ') {
      evt.preventDefault();
      document.getElementById('pauseBtn').click();
    }
  });
  
  updateStatus();

  // Particle colors by status
  const STATUS_COLOR = {
    "Created": "#60a5fa",
    "In Progress": "#fbbf24",
    "Completed": "#34d399",
    "Cancelled": "#f87171"
  };

  function drawCore(totalHeat) {
    const pulse = 20 + Math.sin(Date.now() / 300) * 10 + totalHeat * 0.2;

    const gradient = ctx.createRadialGradient(W/2, H/2, 0, W/2, H/2, pulse * 4);
    gradient.addColorStop(0, "#a78bfa");
    gradient.addColorStop(1, "transparent");

    ctx.fillStyle = gradient;
    ctx.beginPath();
    ctx.arc(W/2, H/2, pulse * 4, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawProgramRing(p) {
    // Angle updated in main loop when animation is running

    const x = W/2 + Math.cos(p.angle) * p.radius;
    const y = H/2 + Math.sin(p.angle) * p.radius;

    ctx.strokeStyle = "#9ca3ff55";
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(x, y, 20, 0, Math.PI * 2);
    ctx.stroke();

    ctx.fillStyle = "#c4b5fd";
    ctx.beginPath();
    ctx.arc(x, y, 6, 0, Math.PI * 2);
    ctx.fill();

    return { x, y };
  }

  function drawParticles(p, origin) {
    p.particles.forEach((r, i) => {
      const angle = (i / p.particles.length) * Math.PI * 2 + Date.now() * 0.0003;
      const dist = 40 + (r.days_to_latest_status || 1) * 2;

      const x = origin.x + Math.cos(angle) * dist;
      const y = origin.y + Math.sin(angle) * dist;

      ctx.fillStyle = STATUS_COLOR[r.latest_status] || "#60a5fa";
      ctx.beginPath();
      ctx.arc(x, y, 3 + Math.log((r.goals + r.notes + r.activity + 1)), 0, Math.PI * 2);
      ctx.fill();
    });
  }

  function loop() {
    ctx.clearRect(0, 0, W, H);

    // Update angles if animation is running
    if (animationRunning) {
      Object.values(programs).forEach(p => {
        p.angle += p.speed;
      });
    }

    let totalHeat = 0;
    rows.forEach(r => totalHeat += (r.goals + r.notes + r.activity));

    drawCore(totalHeat);

    Object.values(programs).forEach(p => {
      const origin = drawProgramRing(p);
      drawParticles(p, origin);
    });

    // Continue animation loop only if running
    if (animationRunning) {
      animationId = requestAnimationFrame(loop);
    } else {
      animationId = null;
    }
  }

  loop();
  } catch (err) {
    console.error('Failed to load referral reactor:', err);
    document.getElementById('loading').style.display = 'none';
    document.getElementById('error').style.display = 'block';
    document.getElementById('error').innerHTML = '<h3>Error loading data</h3><p>' + (err.message || err) + '</p>';
  }
})();
</script>

</body>
</html>
