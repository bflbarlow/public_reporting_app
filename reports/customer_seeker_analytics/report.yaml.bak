# Customer Seeker Analytics Dashboard using Plotly.js
id: customer_seeker_analytics
display_name: "Seeker Analytics Dashboard"
description: "Comprehensive seeker profile analytics and interactive visualizations using Plotly.js"
database: customer_sql
charting_library: "https://cdn.plot.ly/plotly-2.24.1.min.js"

# Immutable parameters define security boundaries
immutable_params:
  organization_id:
    type: number
    required: true
    description: "Organization ID for data segmentation"

# Mutable parameters enable interactive filtering
mutable_params:
  start_date:
    type: date
    default: "2024-01-01"
    description: "Start date for analysis"
  end_date:
    type: date
    default: "2024-12-31"
    description: "End date for analysis"
  profile_status:
    type: string
    default: ""
    description: "Filter by profile status (empty = all)"
  follow_up:
    type: boolean
    default: ""
    description: "Filter by follow-up status (empty = all)"

# Datasources - named SQL queries
datasources:
  # Seeker profile overview
  seeker_profiles:
    sql: |
      SELECT 
        DATE(seeker_profile_created_at) AS profile_date,
        COUNT(*) AS new_profiles,
        COUNT(DISTINCT email) AS unique_emails,
        AVG(CASE WHEN is_archived = 'active' THEN 1 ELSE 0 END) * 100 AS active_rate,
        AVG(CASE WHEN follow_up = 1 THEN 1 ELSE 0 END) * 100 AS follow_up_rate
      FROM seeker_profiles
      WHERE seeker_profile_created_at BETWEEN {{start_date}} AND {{end_date}}
        AND (:profile_status = '' OR is_archived = :profile_status)
        AND (:follow_up = '' OR follow_up = :follow_up)
      GROUP BY DATE(seeker_profile_created_at)
      ORDER BY profile_date
    cache_ttl: 300
    description: "Daily seeker profile creation and status metrics"

  # Seeker geographic distribution
  geographic_distribution:
    sql: |
      SELECT 
        sp.subdomain,
        COUNT(*) AS seeker_count,
        COUNT(DISTINCT sp.email) AS unique_emails,
        COUNT(DISTINCT r.seeker_id) AS referred_seekers,
        AVG(CASE WHEN r.referral_status = 'Completed' THEN 1 ELSE 0 END) * 100 AS referral_completion_rate
      FROM seeker_profiles sp
      LEFT JOIN referrals r ON sp.seeker_id = r.seeker_id
        AND r.referral_date BETWEEN {{start_date}} AND {{end_date}}
      WHERE sp.seeker_profile_created_at BETWEEN {{start_date}} AND {{end_date}}
        AND (:profile_status = '' OR sp.is_archived = :profile_status)
      GROUP BY sp.subdomain
      HAVING COUNT(*) > 0
      ORDER BY seeker_count DESC
    row_limit: 100
    description: "Seeker distribution by subdomain/geography"

  # Seeker engagement metrics
  engagement_metrics:
    sql: |
      SELECT 
        DATE_FORMAT(sp.seeker_profile_created_at, '%Y-%m') AS month,
        COUNT(DISTINCT sp.seeker_id) AS new_seekers,
        COUNT(DISTINCT r.id_referrals) AS total_referrals,
        COUNT(DISTINCT n.id_notes) AS total_notes,
        COUNT(DISTINCT a.id_assessments) AS total_assessments,
        AVG(CASE WHEN r.referral_status = 'Completed' THEN 1 ELSE 0 END) * 100 AS referral_success_rate
      FROM seeker_profiles sp
      LEFT JOIN referrals r ON sp.seeker_id = r.seeker_id
        AND r.referral_date BETWEEN {{start_date}} AND {{end_date}}
      LEFT JOIN notes n ON sp.seeker_id = n.seeker_id
        AND n.note_created_at BETWEEN {{start_date}} AND {{end_date}}
      LEFT JOIN assessments a ON sp.seeker_id = a.seeker_id
        AND a.created_at BETWEEN {{start_date}} AND {{end_date}}
      WHERE sp.seeker_profile_created_at BETWEEN {{start_date}} AND {{end_date}}
        AND (:profile_status = '' OR sp.is_archived = :profile_status)
      GROUP BY DATE_FORMAT(sp.seeker_profile_created_at, '%Y-%m')
      HAVING COUNT(DISTINCT sp.seeker_id) > 0
      ORDER BY month
    cache_ttl: 600
    description: "Monthly seeker engagement metrics across multiple activities"

  # Seeker household analysis
  household_analysis:
    sql: |
      SELECT 
        sh.household_size,
        COUNT(DISTINCT sp.seeker_id) AS seeker_count,
        COUNT(DISTINCT r.id_referrals) AS total_referrals,
        AVG(CASE WHEN r.referral_status = 'Completed' THEN 1 ELSE 0 END) * 100 AS completion_rate,
        COUNT(DISTINCT p.program_numeric_id) AS program_diversity
      FROM seeker_profiles sp
      LEFT JOIN seeker_households sh ON sp.seeker_id = sh.seeker_id
      LEFT JOIN referrals r ON sp.seeker_id = r.seeker_id
        AND r.referral_date BETWEEN {{start_date}} AND {{end_date}}
      LEFT JOIN programs p ON r.program_numeric_id = p.program_numeric_id
      WHERE sp.seeker_profile_created_at BETWEEN {{start_date}} AND {{end_date}}
        AND (:profile_status = '' OR sp.is_archived = :profile_status)
        AND sh.household_size IS NOT NULL
      GROUP BY sh.household_size
      HAVING COUNT(DISTINCT sp.seeker_id) > 0
      ORDER BY sh.household_size
    row_limit: 50
    description: "Analysis of seekers by household size"

  # Seeker activity timeline
  activity_timeline:
    sql: |
      SELECT 
        sp.seeker_id,
        sp.first_name,
        sp.last_name,
        sp.seeker_profile_created_at AS profile_created,
        MIN(r.referral_date) AS first_referral,
        MAX(r.referral_date) AS last_referral,
        COUNT(r.id_referrals) AS referral_count,
        COUNT(DISTINCT r.program_numeric_id) AS program_count
      FROM seeker_profiles sp
      LEFT JOIN referrals r ON sp.seeker_id = r.seeker_id
        AND r.referral_date BETWEEN {{start_date}} AND {{end_date}}
      WHERE sp.seeker_profile_created_at BETWEEN {{start_date}} AND {{end_date}}
        AND (:profile_status = '' OR sp.is_archived = :profile_status)
      GROUP BY sp.seeker_id, sp.first_name, sp.last_name, sp.seeker_profile_created_at
      HAVING COUNT(r.id_referrals) > 0
      ORDER BY referral_count DESC
      LIMIT 50
    row_limit: 100
    description: "Top seekers by referral activity"

# Development settings
development:
  hot_reload: true